# PostgreSQL — connection string for `pg` (see src/lib/db.ts and npm run db:migrate)
DATABASE_URL=postgresql://user:password@localhost:5433/classroom_roster

# NextAuth (v4) — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of this app (no trailing slash). Must match the URL you open in the browser.
NEXTAUTH_URL=http://localhost:3000

# Local uploads directory (production: e.g. /var/app/uploads)
UPLOAD_DIR=./uploads
